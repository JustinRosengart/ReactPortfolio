{
  "name": "claude-portfolio-test",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:3001",
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@marsidev/react-turnstile": "^1.5.0",
    "@supabase/supabase-js": "^2.98.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.539.0",
    "multer": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.8.0",
    "react-scripts": "^5.0.1",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "npm run optimize-images && npm run generate-manifests && react-scripts start",
    "build": "npm run optimize-images && npm run generate-manifests && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "optimize-images": "node scripts/optimizeImages.js",
    "generate-manifests": "node scripts/generateImageManifests.js",
    "dev:builder": "concurrently \"set REACT_APP_ENABLE_BUILDER=true&& npm run start\" \"node server/index.js\"",
    "seed-db": "node scripts/seedSupabase.js",
    "migrate-images": "npm run optimize-images && node scripts/migrateImages.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "**/*.test.tsx",
          "**/*.test.ts"
        ],
        "rules": {
          "testing-library/no-wait-for-multiple-assertions": "off",
          "testing-library/no-node-access": "off",
          "testing-library/no-unnecessary-act": "off",
          "testing-library/await-async-utils": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!(react-router|react-router-dom|react-markdown|devlop|micromark|unist-util|mdast-util|hast-util|remark|lucide-react|@babel|@remix-run|comma-separated-tokens|property-information|space-separated-tokens|estree-util|vfile)/)"
    ]
  },
  "devDependencies": {
    "@types/react-helmet": "^6.1.11",
    "body-parser": "^2.2.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "jest-junit": "^16.0.0",
    "mime-types": "^3.0.2",
    "sharp": "^0.34.3"
  }
}
